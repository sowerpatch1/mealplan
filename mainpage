<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Meal Planner</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f5f5f5;
      padding: 20px;
    }
    h1 {
      text-align: center;
    }
    .container {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 15px;
    }
    .card {
      background: white;
      padding: 15px;
      border-radius: 10px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }
    .card h3 {
      margin-top: 0;
    }
    .tag {
      display: inline-block;
      background: #e0f2f1;
      padding: 3px 8px;
      margin: 2px;
      border-radius: 5px;
      font-size: 12px;
    }
    a {
      color: #0077cc;
      text-decoration: none;
    }
  </style>
</head>
<body>

<h1>My Meal Planner</h1>

<div class="container" id="mealContainer"></div>

<script>
const meals = [
  {
    name: "Peanut Butter Energy Bites",
    calories: 150,
    protein: 6,
    fiber: 3,
    tags: ["High Fiber", "Heart Healthy"],
    link: "https://www.ambitiouskitchen.com/protein-peanut-butter-energy-bites/"
  },
  {
    name: "Chocolate Banana Protein Shake",
    calories: 300,
    protein: 25,
    fiber: 2,
    tags: ["High Protein"],
    link: "https://www.allrecipes.com/recipe/244959/chocolate-banana-peanut-butter-protein-shake/"
  }
];

const container = document.getElementById("mealContainer");

meals.forEach(meal => {
  const div = document.createElement("div");
  div.className = "card";

  div.innerHTML = `
    <h3>${meal.name}</h3>
    <p>Calories: ${meal.calories}</p>
    <p>Protein: ${meal.protein}g</p>
    <p>Fiber: ${meal.fiber}g</p>
    <div>
      ${meal.tags.map(tag => `<span class="tag">${tag}</span>`).join("")}
    </div>
    <p><a href="${meal.link}" target="_blank">View Recipe</a></p>
  `;

  container.appendChild(div);
});
</script>

</body>
</html>
